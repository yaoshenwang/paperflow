            "type": "paragraph",
            "children": [
              { "type": "math_inline", "typst": "sin 30degree + cos 60degree" },
              { "type": "text", "text": " = ________。" }
            ]
          }
        ],
        "answer": [
          {
            "type": "paragraph",
            "children": [{ "type": "math_inline", "typst": "1" }]
          }
        ],
        "analysis": [
          {
            "type": "paragraph",
            "children": [
              { "type": "math_inline", "typst": "sin 30degree = 1/2" },
              { "type": "text", "text": "，" },
              { "type": "math_inline", "typst": "cos 60degree = 1/2" },
              { "type": "text", "text": "，故原式 " },
              { "type": "math_inline", "typst": "= 1/2 + 1/2 = 1" },
              { "type": "text", "text": "。" }
            ]
          }
        ],
