    {
      "id": "qi-003",
      "canonicalId": "cq-003",
      "sourceDocumentId": "sd-002",
      "sourceLocator": { "page": 6, "questionNo": "18" },
      "taxonomy": {
        "subject": "数学",
        "grade": "高一",
        "knowledgeIds": ["func-properties", "func-monotone"],
        "abilityTags": ["推理", "计算"],
        "questionType": "computation",
        "difficulty": 0.7
      },
      "content": {
        "stem": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "已知函数 " },
              { "type": "math_inline", "typst": "f(x) = x^2 - 2x + 3" },
              { "type": "text", "text": "。" }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "（1）求函数 " },
              { "type": "math_inline", "typst": "f(x)" },
              { "type": "text", "text": " 的最小值；" }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "（2）判断 " },
              { "type": "math_inline", "typst": "f(x)" },
              { "type": "text", "text": " 在 " },
              { "type": "math_inline", "typst": "[1, +infinity)" },
              { "type": "text", "text": " 上的单调性，并证明。" }
            ]
          }
        ],
        "answer": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "（1）" },
              { "type": "math_inline", "typst": "f(x) = (x-1)^2 + 2" },
              { "type": "text", "text": "，当 " },
              { "type": "math_inline", "typst": "x = 1" },
              { "type": "text", "text": " 时取最小值 " },
              { "type": "math_inline", "typst": "f(1) = 2" },
              { "type": "text", "text": "。" }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "（2）" },
              { "type": "math_inline", "typst": "f(x)" },
              { "type": "text", "text": " 在 " },
              { "type": "math_inline", "typst": "[1, +infinity)" },
              { "type": "text", "text": " 上单调递增。" }
            ]
          }
        ],
        "analysis": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "配方法可得 " },
              { "type": "math_inline", "typst": "f(x) = (x-1)^2 + 2" },
              { "type": "text", "text": "，顶点为 " },
              { "type": "math_inline", "typst": "(1, 2)" },
              { "type": "text", "text": "。对于单调性证明，取 " },
              { "type": "math_inline", "typst": "x_1 > x_2 >= 1" },
              { "type": "text", "text": "，则 " },
              { "type": "math_inline", "typst": "f(x_1) - f(x_2) = (x_1 - x_2)(x_1 + x_2 - 2) > 0" },
              { "type": "text", "text": "。" }
            ]
          }
        ],
