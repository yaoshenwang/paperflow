      "content": {
        "stem": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "函数 " },
              { "type": "math_inline", "typst": "f(x) = sqrt(x - 1)" },
              { "type": "text", "text": " 的定义域是" }
            ]
          }
        ],
        "options": [
          { "label": "A", "content": [{ "type": "paragraph", "children": [{ "type": "math_inline", "typst": "[1, +infinity)" }] }] },
          { "label": "B", "content": [{ "type": "paragraph", "children": [{ "type": "math_inline", "typst": "(1, +infinity)" }] }] },
          { "label": "C", "content": [{ "type": "paragraph", "children": [{ "type": "math_inline", "typst": "(-infinity, 1]" }] }] },
          { "label": "D", "content": [{ "type": "paragraph", "children": [{ "type": "math_inline", "typst": "(-infinity, 1)" }] }] }
        ],
        "answer": [{ "type": "paragraph", "children": [{ "type": "text", "text": "A" }] }],
        "analysis": [
          {
            "type": "paragraph",
            "children": [
              { "type": "text", "text": "要使 " },
              { "type": "math_inline", "typst": "sqrt(x - 1)" },
              { "type": "text", "text": " 有意义，需 " },
              { "type": "math_inline", "typst": "x - 1 >= 0" },
              { "type": "text", "text": "，即 " },
              { "type": "math_inline", "typst": "x >= 1" },
              { "type": "text", "text": "。故选A。" }
            ]
          }
        ],
